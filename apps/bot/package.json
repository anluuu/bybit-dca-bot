{
  "name": "@dca/bot",
  "version": "1.0.0",
  "description": "Bybit DCA bot service",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "backtest": "tsx src/backtest/cli.ts",
    "fetch-backtest-data": "tsx src/backtest/fetch-data.ts"
  },
  "dependencies": {
    "@dca/shared": "workspace:*",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/csrf-protection": "^7.1.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "axios": "^1.15.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.73.5",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.4",
    "ioredis": "^5.10.1",
    "postgres": "^3.4.9",
    "telegraf": "^4.16.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
