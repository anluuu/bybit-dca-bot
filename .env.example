# Bybit API (sub-account recommended)
BYBIT_API_KEY=
BYBIT_API_SECRET=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# DCA Settings
BUY_AMOUNT_BRL=250
MONTHLY_CAP_BRL=1000
CRON_SCHEDULE=0 8 * * 0
LIMIT_DISCOUNT_PCT=0.3
LIMIT_WAIT_MINUTES=120
TRADING_PAIR=BTCBRL

# Infrastructure
# DATABASE_URL is only used for local dev (pnpm dev). In production,
# docker-compose.yml builds the URL from POSTGRES_PASSWORD automatically.
# For docker-compose.dev.yml databases, use password: devpassword
DATABASE_URL=postgres://dca:devpassword@localhost:5432/dca_bot
REDIS_URL=redis://localhost:6379
PORT=3000
WEB_PORT=8080

# Postgres (used by docker-compose.yml in production)
POSTGRES_PASSWORD=changeme-pick-a-strong-password

# Auth (dashboard)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme-min-8-chars
JWT_SECRET=changeme-at-least-32-characters-long-random-string
