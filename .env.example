# === Bybit (sub-account with spot-trading-only permissions) ===
BYBIT_API_KEY=
BYBIT_API_SECRET=

# === Telegram ===
TELEGRAM_BOT_TOKEN=                  # From @BotFather
TELEGRAM_CHAT_ID=                    # Send /start to your bot, then check getUpdates

# === DCA Settings (defaults work; override to taste) ===
BUY_AMOUNT_BRL=250
MONTHLY_CAP_BRL=1000
CRON_SCHEDULE=0 8 * * 0              # Sunday 08:00 UTC
LIMIT_DISCOUNT_PCT=0.3
LIMIT_WAIT_MINUTES=120
TRADING_PAIR=BTCBRL
TEST_ORDER_AMOUNT_BRL=10              # Size of admin-triggered test market orders

# === Local dev only (overridden by docker-compose.yml in prod) ===
DATABASE_URL=postgres://dca:devpassword@localhost:5432/dca_bot
REDIS_URL=redis://localhost:6379
PORT=3000

# === Auth (dashboard) ===
ADMIN_USERNAME=admin
ADMIN_PASSWORD=                      # Min 8 chars
JWT_SECRET=                          # Min 32 chars — generate: openssl rand -hex 32

# === Set in Dokploy env UI for production (not needed locally if using docker-compose.dev.yml) ===
# POSTGRES_PASSWORD=

# ---- Copy Trader (F0 listener) ----
# Generate with: cd apps/copy-trader && TELEGRAM_API_ID=... TELEGRAM_API_HASH=... pnpm auth
COPY_TG_API_ID=
COPY_TG_API_HASH=
COPY_TG_SESSION_STRING=
COPY_TG_CHANNEL_ID=-1002427024288
COPY_NOTIFY_BOT_TOKEN=
COPY_NOTIFY_CHAT_ID=

# ---- Copy Trader F1 (Bybit) ----
COPY_BYBIT_API_KEY=
COPY_BYBIT_API_SECRET=
COPY_BYBIT_TESTNET=false
COPY_INITIAL_CAPITAL_USDT_OVERRIDE=
