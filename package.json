{
  "name": "bybit-dca-bot",
  "version": "1.0.0",
  "description": "Automated DCA bot for Bybit exchange (monorepo)",
  "private": true,
  "packageManager": "pnpm@10.30.2",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "dev:db": "docker compose -f docker-compose.dev.yml up -d",
    "dev:db:down": "docker compose -f docker-compose.dev.yml down",
    "db:generate": "pnpm --filter @dca/bot db:generate",
    "db:migrate": "pnpm --filter @dca/bot db:migrate"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "msgpackr-extract"
    ]
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^6.0.2"
  }
}
